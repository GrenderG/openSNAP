# Copy this file to `.env` and edit values for your local setup.
# This file is organized by service so it is easier to see what each process uses.

# ============================================================================
# Bootstrap Service
# Handles bootstrap auth/login and tells the client which game server to join.
# ============================================================================

# Bind address for the bootstrap UDP socket.
OPENSNAP_BOOTSTRAP_HOST=0.0.0.0

# Host/IP advertised by the bootstrap service when it needs to return its own
# endpoint. Leave empty to derive it from bind host and client routing.
OPENSNAP_BOOTSTRAP_ADVERTISE_HOST=

# UDP port for the bootstrap service.
OPENSNAP_BOOTSTRAP_PORT=9090

# Fallback game id used when bootstrap cannot reliably identify the requested
# game from the protocol.
OPENSNAP_BOOTSTRAP_DEFAULT_GAME_IDENTIFIER=automodellista

# Shared bootstrap secret used by the login verifier flow.
OPENSNAP_SERVER_SECRET=Totally secret server secret!

# Shared encryption key used for bootstrap payload encryption/decryption.
OPENSNAP_BOOTSTRAP_KEY=SNAP-SWAN


# ============================================================================
# Game / Lobby Service
# Handles lobby, rooms, and in-game session traffic for one configured game.
# ============================================================================

# Bind address for the game UDP socket.
OPENSNAP_GAME_HOST=0.0.0.0

# Host/IP advertised to clients in bootstrap login-success responses for the
# local game server. Leave empty to derive it from bind host and client routing.
OPENSNAP_GAME_ADVERTISE_HOST=

# UDP port for the game service.
OPENSNAP_GAME_PORT=9091

# Logical game identifier for this game server instance.
OPENSNAP_GAME_IDENTIFIER=automodellista

# Game plugin loaded by the game server process.
OPENSNAP_GAME_PLUGIN=automodellista

# Explicit bootstrap redirect map: game_identifier -> host:port.
# For multi-game deployments, define every game the bootstrap server may route.
# Example:
# {"automodellista":"192.168.1.151:9091","monsterhunter":"192.168.1.152:10070"}
# Object values like `{"host": "...", "port": 1234}` are also accepted.
OPENSNAP_GAME_SERVER_MAP={}

# Shared periodic tick interval used by bootstrap and game services.
OPENSNAP_TICK_INTERVAL_SECONDS=10.0

# Global cap on how many lobbies are exposed/accepted by the game service.
OPENSNAP_MAX_LOBBIES=20

# Maximum number of rooms allowed per lobby.
OPENSNAP_MAX_ROOMS_PER_LOBBY=50

# Global room-cap ceiling. Room creation clamps requested max players to this value.
OPENSNAP_MAX_PLAYERS_PER_ROOM=8


# ============================================================================
# Storage
# Shared persistent state used by web, bootstrap, and game services.
# ============================================================================

# SQLite database path. All services should point at the same file.
OPENSNAP_SQLITE_PATH=opensnap.db

# Reset transient runtime state on startup.
# In split mode, the game server clears room state while preserving bootstrap
# sessions so bootstrap-to-game handoff still works.
OPENSNAP_RESET_RUNTIME_ON_STARTUP=true

# Default users inserted in SQLite on startup.
# Format: username:password[:seed[:team]], separated by commas.
OPENSNAP_DEFAULT_USERS=test:1111


# ============================================================================
# Web Service
# Handles registration and web-based account flows.
# ============================================================================

# Bind address for the web server.
OPENSNAP_WEB_HOST=0.0.0.0

# TCP port for the web server.
OPENSNAP_WEB_PORT=80

# Optional HTTPS listener for `rankweb`. Games transitions into
# the web/database flow after post-game lobby leave, and the embedded ranking
# upload URL uses HTTPS. Set both values to enable a local TLS listener.
OPENSNAP_WEB_HTTPS_HOST=0.0.0.0
OPENSNAP_WEB_HTTPS_PORT=443

# TLS certificate/key for the optional HTTPS listener. Leave both blank to
# disable HTTPS until local certificates are available.
OPENSNAP_WEB_HTTPS_CERTFILE=
OPENSNAP_WEB_HTTPS_KEYFILE=

# Web route mode/profile:
# - generic (default): register all bundled web modules at once and answer
#   requests from any of those routes.
# - explicit module name (override): register only that one module.
#   Examples: automodellista, automodellista_beta1, monsterhunter.
OPENSNAP_WEB_GAME_PLUGIN=generic


# ============================================================================
# DNS Service
# Provides static DNS answers for bundled game domains.
# ============================================================================

# Bind address for the DNS server.
OPENSNAP_DNS_HOST=0.0.0.0

# UDP port for the DNS server.
OPENSNAP_DNS_PORT=53

# DNS response TTL in seconds.
OPENSNAP_DNS_TTL=60

# Optional fallback IPv4 used by default bundled-module DNS entries.
OPENSNAP_DNS_DEFAULT_IP=

# Static DNS overrides in JSON or Python-dict form.
# Use "@default" to map a name to OPENSNAP_DNS_DEFAULT_IP, then to the game
# server advertise/bind host fallback chain.
OPENSNAP_DNS_ENTRIES={
  # Auto Modellista Beta 1
  "stage.sega.com": "@default",
  "web.ftpublicbeta.games.sega.net": "@default",
  "bootstrap.ftpublicbeta.games.sega.net": "@default",

  # Auto Modellista
  "bootstrap.capcom-am.games.sega.net": "@default",
  "gameweb.capcom-am.games.sega.net": "@default",
  "rankweb.capcom-am.games.sega.net": "@default",
  "regweb.capcom-am.games.sega.net": "@default",

  # Monster Hunter USA
  "regweb.mh.capcom.sf.yav4.com": "@default",
  "bootstrap01.sf.yav4.com": "@default",
  "app01.reo.capcom.sf.yav4.com": "@default",

  # Monster Hunter PAL (and Demo)
  "bootstrap01.mheu-beta.capcom.sf.yav.com": "@default",

  # Monster Hunter USA Public Beta
  "regweb.reo.capcom.sf.yav4.com": "@default",
  "snap01.reo.capcom.sf.yav4.com": "@default"}


# ============================================================================
# Logging
# Shared logging configuration for all services.
# ============================================================================

# Console/file log verbosity: debug, info, warn, warning, error, critical.
OPENSNAP_LOG_LEVEL=debug

# Optional directory for persistent logs in addition to stdout.
OPENSNAP_LOG_PATH=

# Max bytes shown in packet hexdumps. Set to 0 for unlimited output.
OPENSNAP_LOG_HEXDUMP_LIMIT=16384
